{
  "name": "@cyanheads/openaq-mcp-server",
  "version": "0.1.1",
  "mcpName": "io.github.cyanheads/openaq-mcp-server",
  "description": "Find air-quality monitoring stations and read measured pollutant observations (PM2.5, PM10, O3, NO2, SO2, CO, and more) from government monitors worldwide via the OpenAQ v3 API, with DataCanvas SQL over historical series.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openaq-mcp-server": "dist/index.js"
  },
  "files": [
    "changelog/",
    "dist/",
    "README.md",
    "LICENSE",
    "CLAUDE.md",
    "AGENTS.md",
    "Dockerfile",
    "server.json"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "rebuild": "bun run scripts/clean.ts && bun run scripts/build.ts",
    "clean": "bun run scripts/clean.ts",
    "devcheck": "bun run scripts/devcheck.ts",
    "audit:refresh": "rm -f bun.lock && bun install && bun audit",
    "tree": "bun run scripts/tree.ts",
    "list-skills": "bun run scripts/list-skills.ts",
    "format": "biome check --write .",
    "format:unsafe": "biome check --write --unsafe .",
    "lint:mcp": "bun run scripts/lint-mcp.ts",
    "lint:packaging": "bun run scripts/lint-packaging.ts",
    "bundle": "bun run build && npx -y @anthropic-ai/mcpb pack . dist/openaq-mcp-server.mcpb && bun run scripts/clean-mcpb.ts dist/openaq-mcp-server.mcpb",
    "changelog:build": "bun run scripts/build-changelog.ts",
    "changelog:check": "bun run scripts/build-changelog.ts --check",
    "release:github": "bun run scripts/release-github.ts",
    "publish-mcp": "mcp-publisher login github -token \"$(security find-generic-password -a \"$USER\" -s mcp-publisher-github-pat -w)\" && mcp-publisher publish",
    "test": "vitest run",
    "start": "node dist/index.js",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "typescript",
    "bun",
    "stdio",
    "streamable-http",
    "openaq",
    "air-quality",
    "pm25",
    "pollution",
    "environment"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/openaq-mcp-server.git"
  },
  "homepage": "https://github.com/cyanheads/openaq-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/cyanheads/openaq-mcp-server/issues"
  },
  "author": "cyanheads <casey@caseyjhand.com>",
  "license": "Apache-2.0",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.10.6",
    "@duckdb/node-api": "^1.5.3-r.3",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "25.9.3",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
